__pycache__/
*.py[cod]
*.pyo
.venv/
.uv/
dist/
build/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Notebooks checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Éditeurs
.vscode/
.idea/
*.swp
*.swo
